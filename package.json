{
  "name": "japanese-full-sentence-trainer",
  "version": "0.3.6",
  "private": true,
  "type": "commonjs",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "version.json",
      "scripts/version.js"
    ]
  },
  "scripts": {
    "version:set": "node scripts/set-version.js",
    "start": "node server.js",
    "dev": "node server.js",
    "package:mac-arm64": "node scripts/package-release.js macos-arm64",
    "package:mac-x64": "node scripts/package-release.js macos-x64",
    "package:win-x64": "node scripts/package-release.js win-x64",
    "package:linux-x64": "node scripts/package-release.js linux-x64",
    "package:all": "node scripts/package-release.js all"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "latest"
  }
}
